# ── Required ──
SIEGE_ANTHROPIC_API_KEY=your-api-key-here
SIEGE_JWT_SECRET_KEY=change-me-to-a-random-string

# ── LLM ──
SIEGE_DEFAULT_MODEL=claude-sonnet-4-20250514
SIEGE_DEFAULT_TEMPERATURE=0.3
SIEGE_MAX_CONCURRENT_LLM_CALLS=5
SIEGE_LLM_RETRY_MAX_ATTEMPTS=3
SIEGE_LLM_RETRY_BASE_DELAY=1.0

# ── Auth ──
SIEGE_JWT_EXPIRY_HOURS=720

# ── Database ──
SIEGE_DATABASE_URL=sqlite:///data/siege_engine.db

# ── Git ──
SIEGE_GIT_REPOS_BASE_PATH=data/repos

# ── GitHub OAuth (optional — needed for PR features) ──
SIEGE_GITHUB_CLIENT_ID=
SIEGE_GITHUB_CLIENT_SECRET=

# ── Server ──
SIEGE_CORS_ORIGINS=["http://localhost:5173"]
