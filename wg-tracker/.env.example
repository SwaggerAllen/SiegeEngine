# Copy to .env for local development. Real secrets are NEVER committed.
# On Digital Ocean App Platform these are set as encrypted env vars / components.

# PostgreSQL connection. The app normalizes postgres:// -> postgresql+psycopg://
DATABASE_URL=postgresql+psycopg://wg:wg@localhost:5432/wgtracker

# Anthropic API key for Batch API summarization + categorization.
ANTHROPIC_API_KEY=sk-ant-...

# Path to the non-secret application config (defaults to ./config.yaml).
CONFIG_PATH=./config.yaml

# Secret used to sign session cookies for the web UI. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string

# Logging
LOG_LEVEL=INFO

# Public base URL of the web UI, used to render absolute invite links.
# e.g. https://wg-tracker.example.com  (no trailing slash)
PUBLIC_BASE_URL=http://localhost:8000
